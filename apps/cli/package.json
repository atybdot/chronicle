{
  "name": "@atybdot/chronicle",
  "version": "0.1.0",
  "description": "AI-powered CLI that transforms uncommitted changes into a realistic git commit history.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "type": "module",
  "bin": {
    "chronicle": "dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target bun --compile",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt src",
    "prepublishOnly": "bun run build",
    "release": "standard-version"
  },
  "keywords": [
    "git",
    "commit",
    "history",
    "backfill",
    "cli",
    "ai",
    "conventional-commits",
    "bun"
  ],
  "author": "atybdot",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atybdot/chronicle.git"
  },
  "bugs": {
    "url": "https://github.com/atybdot/chronicle/issues"
  },
  "homepage": "https://chronicle.atyb.me",
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "oxfmt": "^0.16.0",
    "oxlint": "^0.16.0",
    "standard-version": "^9.3.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.36",
    "@ai-sdk/google": "^3.0.20",
    "@ai-sdk/openai": "^3.0.25",
    "@clack/prompts": "^1.0.0",
    "@trpc/server": "^11.9.0",
    "ai": "^6.0.69",
    "better-result": "^2.7.0",
    "picocolors": "^1.1.1",
    "trpc-cli": "^0.12.2",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ]
}
