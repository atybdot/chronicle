---
import BackLink from "@/components/back-link.astro";
import IndexLayout from "../layouts/index-layout.astro";
import { Code } from "astro:components";

const pageTitle = "Configuration — chronicle";
const pageDescription = "Chronicle configuration options and setup guide.";
const pageKeywords = "chronicle config, configuration, setup, LLM providers, API keys";

const providers = [
  { name: "OpenAI", key: "openai" },
  { name: "Anthropic", key: "anthropic" },
  { name: "Google Gemini", key: "gemini" },
  { name: "OpenRouter", key: "openrouter" },
  { name: "Ollama", key: "ollama", hint: "Local, no API key" },
  { name: "Cloudflare AI Gateway", key: "cloudflare", hint: "Account ID, Gateway ID, API token" },
  { name: "OpenCode Zen", key: "opencode-zen" },
  { name: "Groq", key: "groq" },
];

const configFields = [
  { key: "llm.selected.provider", desc: "Currently active provider" },
  { key: "llm.selected.model", desc: "Currently active model" },
  { key: "llm.providers[]", desc: "Saved provider credentials and provider-specific settings" },
  { key: "llm.customPrompt", desc: "Optional custom instructions for AI output" },
  { key: "git.authorName / git.authorEmail", desc: "Stored git identity fallback" },
  { key: "defaults.*", desc: "Backfill defaults like timeline and work hours" },
];

const configExample = `{
  "llm": {
    "selected": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-20250514"
    },
    "providers": [
      {
        "name": "anthropic",
        "API_TOKEN": "***",
        "model": "claude-sonnet-4-20250514"
      },
      {
        "name": "ollama",
        "baseUrl": "http://localhost:11434",
        "model": "llama3.2"
      }
    ]
  }
}`;
---

<IndexLayout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  canonicalPath="/configuration/"
>
  <div class="px-6 py-12 pt-24 space-y-8" transition:name="page-content">
    <BackLink />

    <section>
      <h1 class="text-3xl font-semibold tracking-tighter mb-3">Configuration</h1>
      <p class="text-zinc-500 text-sm">
        Setup and customize chronicle.
      </p>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-medium">Quick Setup</h2>
      <Code
        code="chronicle config init"
        class="px-4 py-2.5 text-sm **:bg-transparent! bg-zinc-900! rounded-lg"
        theme="ayu-mirage"
        lang="bash"
      />
      <p class="text-xs text-zinc-600">
        Interactive wizard to configure provider, model, and API key.
      </p>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-medium">Providers</h2>
      <div class="p-4 rounded-lg bg-zinc-900">
        <ul class="text-sm space-y-1.5">
          {
            providers.map((p) => (
              <li class="flex gap-3 items-center">
                <code class="text-cyan-400">{p.key}</code>
                <span class="text-zinc-500">{p.name}</span>
                {p.hint && <span class="text-xs text-zinc-600">({p.hint})</span>}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-medium">Environment Variables</h2>
      <div class="space-y-2">
        <Code
          code={`# Standard hosted providers
export CHRONICLE_AI_KEY=your-api-key

# Cloudflare AI Gateway
export CF_ACCOUNT_ID=your-account-id
export CF_GATEWAY_ID=your-gateway-id
export CF_API_TOKEN=your-api-token`}
          class="px-4 py-2.5 text-sm **:bg-transparent! bg-zinc-900! rounded-lg"
          theme="ayu-mirage"
          lang="bash"
        />
        <p class="text-xs text-zinc-600">
          Ollama only needs a base URL. You can also enter credentials during <code class="text-zinc-400">config init</code>. Config is stored at <code class="text-zinc-400">~/.config/chronicle/config.json</code>.
        </p>
      </div>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-medium">Stored Fields</h2>
      <div class="p-4 rounded-lg bg-zinc-900 overflow-x-auto">
        <table class="text-sm w-full">
          <thead>
            <tr class="text-zinc-400 text-left">
              <th class="pb-2 pr-4 font-medium">Field</th>
              <th class="pb-2 pr-4 font-medium">Description</th>
            </tr>
          </thead>
          <tbody class="text-zinc-500">
            {
              configFields.map((opt) => (
                <tr>
                  <td class="py-1 pr-4">
                    <code class="text-cyan-400">{opt.key}</code>
                  </td>
                  <td class="py-1 pr-4">{opt.desc}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-medium">Config Shape</h2>
      <Code
        code={configExample}
        class="px-4 py-3 text-sm **:bg-transparent! bg-zinc-900! rounded-lg"
        theme="ayu-mirage"
        lang="json"
      />
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-medium">Examples</h2>
      <div class="space-y-2">
        <Code
          code={`# Run full setup
chronicle config init

# Switch providers without overwriting saved credentials
chronicle config provider

# Change the model for the selected provider
chronicle config model

# Show current config
chronicle config show`}
          class="px-4 py-3 text-sm **:bg-transparent! bg-zinc-900! rounded-lg"
          theme="ayu-mirage"
          lang="bash"
        />
      </div>
    </section>

  </div>
</IndexLayout>
