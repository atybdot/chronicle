---
import BackLink from "@/components/back-link.astro";
import IndexLayout from "../layouts/index-layout.astro";
import { Code } from "astro:components";

const pageTitle = "Telemetry — chronicle";
const pageDescription = "What chronicle collects, why, and how to opt-out.";
const pageKeywords = "chronicle telemetry, privacy, opt-out, anonymous data";

const collected = [
  "Command names, command success/failure, and duration",
  "Commit and file counts for analyze/backfill events",
  "Configured AI provider, model category, request type, cache hit, and latency",
  "CLI version, OS type, and basic setup/config event metadata",
];

const notCollected = [
  "Source code, diffs, or file contents",
  "Commit messages, file paths, or repository URLs",
  "API keys, credentials, or access tokens",
  "Personal data sent through your repo or prompts",
];
---

<IndexLayout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  canonicalPath="/telemetry/"
>
  <div class="px-6 py-12 pt-24 space-y-8" transition:name="page-content">
    <BackLink />

    <section>
      <h1 class="text-3xl font-semibold tracking-tighter mb-3">Telemetry</h1>
      <p class="text-zinc-500 text-sm">
        Usage telemetry helps improve chronicle. It does not include your code or repo metadata.
      </p>
    </section>

    <section class="grid md:grid-cols-2 gap-4">
      <div class="p-4 rounded-lg bg-zinc-900">
        <h2 class="text-sm font-medium text-zinc-300 mb-3">Collected</h2>
        <ul class="text-sm text-zinc-500 space-y-1">
          {
            collected.map((item) => (
              <li class="flex items-center gap-2">
                <span class="text-green-500">+</span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="p-4 rounded-lg bg-zinc-900">
        <h2 class="text-sm font-medium text-zinc-300 mb-3">Not Collected</h2>
        <ul class="text-sm text-zinc-500 space-y-1">
          {
            notCollected.map((item) => (
              <li class="flex items-center gap-2">
                <span class="text-red-500">-</span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="space-y-2 text-sm text-zinc-600">
      <h2 class="text-lg font-medium text-zinc-300">Note</h2>
      <p>
        During <code class="text-zinc-400">analyze</code> and <code class="text-zinc-400">backfill</code>, code and other text-like changes may be sent to your configured AI provider to generate commit plans and messages. That provider traffic is separate from Chronicle telemetry.
      </p>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-medium">Opt-Out</h2>
      <div class="space-y-2">
        <Code
          code="chronicle config telemetry --opt-out"
          class="px-4 py-2.5 text-sm **:bg-transparent! bg-zinc-900! rounded-lg"
          theme="ayu-mirage"
          lang="bash"
        />
        <p class="text-xs text-zinc-600">
          Or set <code class="text-zinc-400">CHRONICLE_TELEMETRY=false</code> in your
          shell.
        </p>
      </div>
    </section>

    <section class="text-sm text-zinc-600 space-y-2 pb-8">
      <p>
        Local telemetry state and pending events are stored at <code class="text-zinc-400">~/.config/chronicle/telemetry.json</code> and <code class="text-zinc-400">~/.config/chronicle/telemetry-events.jsonl</code>
      </p>
      <p>
        <a
          href="https://github.com/atybdot/chronicle/blob/main/apps/cli/src/lib/telemetry.ts"
          class="text-sky-500 hover:text-sky-400 underline"
          target="_blank"
          rel="noopener noreferrer">View source</a
        >
        <span class="text-zinc-700 mx-2">·</span>
        <a
          href="https://github.com/atybdot/chronicle/issues"
          class="text-sky-500 hover:text-sky-400 underline"
          target="_blank"
          rel="noopener noreferrer">Questions?</a
        >
      </p>
    </section>
  </div>
</IndexLayout>
