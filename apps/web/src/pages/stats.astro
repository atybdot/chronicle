---
import BackLink from "@/components/back-link.astro";
import IndexLayout from "../layouts/index-layout.astro";
import StatsDashboard from "@react/stats-dashboard";
import { ErrorBoundary } from "@react/error-boundary";
import type { StatsData } from "@/types/stats";

const pageTitle = "Usage Stats — chronicle";
const pageDescription = "Public telemetry statistics for chronicle CLI usage.";
const pageKeywords =
  "chronicle stats, telemetry, usage statistics, CLI analytics";

export const prerender = false;

const DEFAULT_TELEMETRY_API = import.meta.env.TELEMETRY_API_URL;
const LOCAL_TELEMETRY_API = "http://localhost:8787";
const configuredTelemetryApi = import.meta.env.TELEMETRY_API_URL;

function getTelemetryApis() {
  if (import.meta.env.DEV) {
    return [
      configuredTelemetryApi,
      LOCAL_TELEMETRY_API,
      DEFAULT_TELEMETRY_API,
    ].filter((value): value is string => Boolean(value));
  }

  return [DEFAULT_TELEMETRY_API, configuredTelemetryApi].filter(
    (value): value is string => Boolean(value) && value !== LOCAL_TELEMETRY_API,
  );
}

async function fetchStats(): Promise<StatsData> {
  for (const api of getTelemetryApis()) {
    try {
      const response = await fetch(`${api}/v1/stats`, {
        signal: AbortSignal.timeout(5000),
      });

      if (!response.ok) continue;

      return await response.json();
    } catch (error) {
      console.error(`Failed to fetch stats from ${api}:`, error);
    }
  }

  return {
    unique_users: 0,
    total_commits: 0,
    total_files: 0,
    total_backfills: 0,
    ai_providers: {},
    ai_requests: 0,
    activity_by_day: [],
    commands: {},
    date_ranges: {},
    model_categories: {},
  };
}

const stats = await fetchStats();
---

<IndexLayout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  canonicalPath="/stats/"
>
  <div class="px-6 py-12 pt-24 space-y-8" transition:name="page-content">
    <BackLink />

    <section>
      <h1 class="text-3xl font-semibold tracking-tighter mb-3">Usage Stats</h1>
      <p class="text-zinc-500 text-sm">
        Public telemetry statistics from chronicle CLI.
        <a href="/telemetry" class="text-sky-500 hover:text-sky-400 underline"
          >Learn what we collect</a
        >.
      </p>
    </section>

    <section class="pb-8">
      <ErrorBoundary client:load>
        <StatsDashboard stats={stats} client:load />
      </ErrorBoundary>
    </section>
  </div>
</IndexLayout>
