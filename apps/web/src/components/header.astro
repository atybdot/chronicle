---
import MobileNav from "@react/mobile-nav";
import { type NavLinks } from "@/types";
const links: NavLinks = [
  { href: "/", label: "home" },
  { href: "/stats", label: "stats" },
  { href: "/configuration", label: "config" },
  { href: "/commands", label: "commands" },
];
const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<header class="absolute top-0 right-0 px-6 sm:py-6 z-10">
  <div class="max-w-3xl mx-auto flex justify-end items-center gap-4">
    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-4 text-sm text-zinc-500">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "transition-colors",
              isActive(link.href) ? "text-sky-500" : "hover:text-zinc-100",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Mobile nav -->
    <div class="md:hidden">
      <div class="text-zinc-500 p-1 opacity-0 md:hidden">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          ><g fill="none" stroke="currentColor" stroke-width="1.5"
            ><path
              d="M2 12c0-3.69 0-5.534.814-6.841a4.8 4.8 0 0 1 1.105-1.243C5.08 3 6.72 3 10 3h4c3.28 0 4.919 0 6.081.916c.43.338.804.759 1.105 1.243C22 6.466 22 8.31 22 12s0 5.534-.814 6.841a4.8 4.8 0 0 1-1.105 1.243C18.92 21 17.28 21 14 21h-4c-3.28 0-4.919 0-6.081-.916a4.8 4.8 0 0 1-1.105-1.243C2 17.534 2 15.69 2 12Z"
            ></path><path stroke-linejoin="round" d="M2 14.5h20"></path><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18h1m3 0h1"></path></g
          ></svg
        >
      </div>
      <MobileNav links={links} currentPath={currentPath} client:only="react" />
    </div>
  </div>
</header>
