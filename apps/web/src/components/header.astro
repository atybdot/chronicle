---
import MobileNav from "@react/mobile-nav";
import NpmIcon from "@/components/icons/npm";
import GithubIcon from "@/components/icons/github";
import { type NavLinks } from "@/types/types";
const links: NavLinks = [
  { href: "/", label: "home" },
  { href: "/stats", label: "stats" },
  { href: "/configuration", label: "config" },
  { href: "/commands", label: "commands" },
];
const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<header class="absolute top-4 right-0 px-6 sm:py-6 z-10">
  <div class="max-w-3xl mx-auto flex justify-end items-center gap-4">
    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-4 text-sm text-zinc-500">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "transition-colors",
              isActive(link.href) ? "text-sky-500" : "hover:text-zinc-100",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="https://github.com/atybdot/chronicle"
        target="_blank"
        rel="noopener noreferrer"
        class="text-zinc-100"
      >
        <GithubIcon />
      </a>
      <a
        href="https://www.npmjs.com/packages/@atybdot/chronicle"
        target="_blank"
        rel="noopener noreferrer"
        class=""
      >
        <NpmIcon />
      </a>
    </nav>

    <!-- Mobile nav -->
    <div class="md:hidden">
      <MobileNav links={links} currentPath={currentPath} client:only="react" />
    </div>
  </div>
</header>
