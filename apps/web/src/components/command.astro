---
import { Code } from "astro:components";
const usage = `analyze   [options]    Analyze uncommitted changes and generate a commit plan
backfill  [options]    Backfill git history with intelligent commit splitting
config                 Available subcommands: init, show, set, get, model, provider, clear-cache, cache-stats, telemetry
status    [options]    Show status of current repository changes
help      [command]    display help for command
`;
---

<section class="bg-zinc-900 rounded-lg">
    <div class="rounded-lg overflow-hidden">
        <div class="flex justify-between items-center px-4 py-2 bg-zinc-800">
            <span class="text-sm text-zinc-500">commands</span>
        </div>
        <Code
            code={usage}
            theme={"ayu-mirage"}
            lang="bash"
            class={"**:bg-transparent! bg-zinc-900! text-sm! px-4 py-6 leading-loose"}
        />
    </div>
</section>
