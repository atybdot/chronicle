{
  "name": "web",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "astro": "astro",
    "lint": "oxlint .",
    "db:migrate": "wrangler d1 migrations apply chronicle-telemetry --remote",
    "db:migrate:local": "wrangler d1 migrations apply chronicle-telemetry --local",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:studio:remote": "DRIZZLE_REMOTE=true drizzle-kit studio",
    "db:seed": "npx tsx scripts/seed.ts 500 30 | wrangler d1 execute chronicle-telemetry --local --file=-",
    "db:seed:remote": "npx tsx scripts/seed.ts 500 30 | wrangler d1 execute chronicle-telemetry --remote --file=-",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.0",
    "@hono-rate-limiter/cloudflare": "^0.2.2",
    "@hono/zod-validator": "^0.7.6",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.0.0-beta.6",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.11.9",
    "hono-rate-limiter": "^0.5.3",
    "lucide-react": "^0.564.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "2.15.4",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "vaul": "^1.1.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260213.0",
    "@faker-js/faker": "^10.3.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "shadcn": "^3.8.4",
    "tw-animate-css": "^1.4.0",
    "wrangler": "^4.65.0"
  }
}