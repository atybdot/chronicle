{
  "$schema": "https://oxc.rs/schema/oxlintrc.json",
  "plugins": ["import", "typescript", "unicorn"],
  "env": {
    "node": true,
    "es2024": true
  },
  "globals": {
    "Bun": "readonly"
  },
  "rules": {
    "no-console": "off",
    "no-debugger": "error",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "prefer-const": "error",
    "no-var": "error"
  },
  "ignorePatterns": ["dist", "node_modules", "*.d.ts"]
}
